{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=MAHIR;Database=Finflow;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "Jwt": {
    "Key": "JWT_AUTHENTICATION_KEY_SECRET",
    "Issuer": "MyApp",
    "Audience": "MyUsers",
    "AccessTokenExpiryMinutes": 10,
    "RefreshTokenExpiryDays": 7
  },

  "Security": {
    "Pepper": "MY_GLOBAL_SECRET_PEPPER"
  }
}
