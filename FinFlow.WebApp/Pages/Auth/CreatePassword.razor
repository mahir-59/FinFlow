@page "/create-password"
<PageTitle>Create Password</PageTitle>
<div class="create-password-page">

    <div class="left-panel">

        <div class="brand">
            <img src="images/FinflowLogo.png" alt="FinFlow" />
        </div>

        <div class="left-content-card">

            <div class="icon-box">
                <i class="fa-solid fa-lock"></i>
            </div>

            <h1>
                Create a new password
            </h1>

            <p>
                Your new password must be unique
                and secure for better account protection.
            </p>

            <div class="security-card">

                <div class="security-item">
                    <i class="@passwordStrengthModel.LengthIcon" style="@passwordStrengthModel.LengthColor"></i>
                    Minimum 8 characters
                </div>

                <div class="security-item">
                    <i class="@passwordStrengthModel.NumberIcon" style="@passwordStrengthModel.NumberColor"></i>
                    Include number
                </div>
                
                <div class="security-item">
                    <i class="@passwordStrengthModel.UpperCaseIcon" style="@passwordStrengthModel.UpperCaseColor"></i>
                    Include uppercase & lowercase
                </div>

                <div class="security-item">
                    <i class="@passwordStrengthModel.SpecialCharacterIcon" style="@passwordStrengthModel.SpecialCharacterColor"></i>
                    Include number & special character
                </div>

            </div>

        </div>

        <div class="footer">
            © 2026 FinFlow. All rights reserved.
        </div>

    </div>

    <div class="right-panel">

        <div class="password-card">

            <h2>Create Password</h2>

            <p class="subtitle">
                Set a strong password for your account
            </p>

            <EditForm Model="@passwordModel"
                      OnValidSubmit="CreatePasswordBtn">

                <div class="input-groups">

                    <label>New Password</label>

                    <div class="password-box">

                        <input @bind="Password"
                            @bind:event="oninput"
                            type="@PasswordType"
                            class="form-input"
                            placeholder="Enter new password" />

                        <button type="button"
                                class="eye-btn"
                                @onclick="TogglePassword">

                            @if (showPassword)
                            {
                                <i class="fa-solid fa-eye-slash"></i>
                            }
                            else
                            {
                                <i class="fa-solid fa-eye"></i>
                            }

                        </button>

                    </div>

                </div>

                <div class="input-groups">

                    <label>Confirm Password</label>

                    <div class="password-box">

                        <InputText @bind-Value="passwordModel.ConfirmPassword"
                                   type="@ConfirmPasswordType"
                                   class="form-input"
                                   placeholder="Confirm password" />

                        <button type="button"
                                class="eye-btn"
                                @onclick="ToggleConfirmPassword">

                            @if (showConfirmPassword)
                            {
                                <i class="fa-solid fa-eye-slash"></i>
                            }
                            else
                            {
                                <i class="fa-solid fa-eye"></i>
                            }

                        </button>

                    </div>

                </div>

               <div class="password-strength @PasswordStrength.ToLower()">

                    <div class="strength-bars">

                        <div class="bar @(StrengthLevel >= 1 ? "active" : "")"></div>

                        <div class="bar @(StrengthLevel >= 2 ? "active" : "")"></div>

                        <div class="bar @(StrengthLevel >= 3 ? "active" : "")"></div>

                        <div class="bar @(StrengthLevel >= 4 ? "active" : "")"></div>

                    </div>

                    <span>@PasswordStrength</span>

                </div>

                <button type="submit"
                        class="create-btn">
                    Create Password
                </button>

            </EditForm>

        </div>

    </div>

</div>
