@page "/order-confirmed"

<div class="ffoc-page">

    <div class="ffoc-card">

        <div class="ffoc-success-area">

            <div class="ffoc-success-gif-wrapper">

                <img src="images/check.png"
                    alt="Order Success"
                    class="ffoc-success-gif" />

            </div>

            <h1 class="ffoc-title">
                Order placed successfully!
            </h1>

            <div class="ffoc-subtitle">
                Order #ORD-204 confirmed
            </div>

        </div>

        <div class="ffoc-order-summary">

            <div class="ffoc-item-row">

                <div>
                    Namkeen carton × 2
                </div>

                <div>
                    ₹800
                </div>

            </div>

            <div class="ffoc-item-row">

                <div>
                    Biscuit carton × 1
                </div>

                <div>
                    ₹300
                </div>

            </div>

            <div class="ffoc-divider"></div>

            <div class="ffoc-total-row">

                <span>Total</span>

                <span>₹1100</span>

            </div>

        </div>

        <div class="ffoc-invoice-card">

            <div class="ffoc-invoice-icon">

                <i class="fa-regular fa-file-lines"></i>

            </div>

            <div>

                <div class="ffoc-invoice-title">
                    Invoice INV-1004 created
                </div>

                <div class="ffoc-invoice-text">
                    ₹1100 · due in 30 days · not yet paid.
                    Find it in the invoices tab.
                </div>

            </div>

        </div>

        <button class="ffoc-primary-btn">
            View Orders
        </button>

        <button class="ffoc-secondary-btn">
            Continue Shopping
        </button>

    </div>

</div>