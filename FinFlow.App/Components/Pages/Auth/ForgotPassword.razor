@page "/forgot-password"
@layout MainLayout


<div class="ff-forgot-shell">

    <button class="ff-forgot-back"
            @onclick="GoBack">
        ←
    </button>

    <h1 class="ff-forgot-heading">
        Forgot Password?
    </h1>

    <p class="ff-forgot-description">
        Enter your email address and
        we'll help you reset it.
    </p>

    <div class="ff-forgot-field">

        <label class="ff-forgot-field-label">
            Email Address
        </label>

        <input class="ff-forgot-email-input"
               type="email"
               placeholder="john@example.com" />

    </div>

    <button class="ff-forgot-send-btn"
            @onclick="SendOtp">
        Send OTP
    </button>

    <button class="ff-forgot-login-link"
            @onclick="@(() => _navigationManager.NavigateTo("/"))">

        Back to login

    </button>

</div>
