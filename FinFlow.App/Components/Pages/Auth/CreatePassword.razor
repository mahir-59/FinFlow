@page "/create-password"
@layout MainLayout



<div class="ff-cpwd-shell">

    <div class="ff-cpwd-content">

        <button class="ff-cpwd-back"
                @onclick="GoBack">
            ←
        </button>

        <h1 class="ff-cpwd-heading">
            Create New Password
        </h1>

        <p class="ff-cpwd-description">
            Enter your new password below
        </p>

        <div class="ff-cpwd-field">

            <label class="ff-cpwd-label">
                New Password
            </label>

            <div class="ff-cpwd-password-wrapper">

                <input class="ff-cpwd-input"
                       type="@(ShowPassword ? "text" : "password")"
                       @bind="Password"
                       @bind:event="oninput" />

                <button type="button"
                        class="ff-cpwd-eye-toggle"
                        @onclick="TogglePassword">

                    <i class="@(ShowPassword ? "fa-solid fa-eye-slash" : "fa-solid fa-eye")"></i>

                </button>

            </div>

        </div>

        <div class="ff-cpwd-field">

            <label class="ff-cpwd-label">
                Confirm Password
            </label>

            <div class="ff-cpwd-password-wrapper">

                <input class="ff-cpwd-input @(Password != ConfirmPassword && !string.IsNullOrEmpty(ConfirmPassword) ? "ff-cpwd-input-error" : "")""
                       type="@(ShowConfirmPassword ? "text" : "password")"
                       @bind="ConfirmPassword" />

                <button type="button"
                        class="ff-cpwd-eye-toggle"
                        @onclick="ToggleConfirmPassword">

                    <i class="@(ShowConfirmPassword ? "fa-solid fa-eye-slash" : "fa-solid fa-eye")"></i>

                </button>

            </div>

        </div>

        <div class="ff-cpwd-strength-label ff-cpwd-text-@StrengthClass">
            @StrengthText
        </div>

        <div class="ff-cpwd-strength-bars">

            @for (int i = 1; i <= 4; i++)
            {
                <div class="ff-cpwd-strength-segment
                    @(StrengthLevel >= i ? $"ff-cpwd-bar-{StrengthClass}" : "")">
                </div>
            }

        </div>

        <div class="ff-cpwd-rules">

            <div class="ff-cpwd-rule-item">
                <span class="@(HasMinLength ? "ff-cpwd-rule-success" : "ff-cpwd-rule-fail")">
                    @(HasMinLength ? "✔" : "✖")
                </span>
                At least 8 characters
            </div>

            <div class="ff-cpwd-rule-item">
                <span class="@(HasUpperCase ? "ff-cpwd-rule-success" : "ff-cpwd-rule-fail")">
                    @(HasUpperCase ? "✔" : "✖")
                </span>
                At least one uppercase letter
            </div>

            <div class="ff-cpwd-rule-item">
                <span class="@(HasLowerCase ? "ff-cpwd-rule-success" : "ff-cpwd-rule-fail")">
                    @(HasLowerCase ? "✔" : "✖")
                </span>
                At least one lowercase letter
            </div>

            <div class="ff-cpwd-rule-item">
                <span class="@(HasNumber ? "ff-cpwd-rule-success" : "ff-cpwd-rule-fail")">
                    @(HasNumber ? "✔" : "✖")
                </span>
                At least one number
            </div>

            <div class="ff-cpwd-rule-item">
                <span class="@(HasSpecialCharacter ? "ff-cpwd-rule-success" : "ff-cpwd-rule-fail")">
                    @(HasSpecialCharacter ? "✔" : "✖")
                </span>
                At least one special character
            </div>

        </div>

        @if (!string.IsNullOrEmpty(ConfirmPassword) &&
             Password != ConfirmPassword)
        {
            <div class="ff-cpwd-error">
                Passwords do not match
            </div>
        }

    </div>

    <button class="ff-cpwd-submit"
            disabled="@(Password != ConfirmPassword)"
            @onclick="ResetPassword">

        Reset Password

    </button>

</div>
