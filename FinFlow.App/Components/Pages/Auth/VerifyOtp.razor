@page "/verify-otp"
@layout MainLayout

<div class="otp-page">

    <button class="back-btn">←</button>

    <h1 class="title">Enter OTP</h1>

    <p class="description">
        Enter the 6-digit code sent to
    </p>

    <p class="email">
        john@example.com
    </p>

    <div class="otp-wrapper"
         @onclick="FocusInput">

        <input @ref="_otpInput"
               class="hidden-input"
               maxlength="6"
               inputmode="numeric"
               value="@OtpValue"
               @oninput="HandleOtpInput" />

        @for (int i = 0; i < 6; i++)
        {
            var isActive = OtpValue.Length == i;
            var isFilled = OtpValue.Length > i;

            <div class="otp-box
                @(isActive ? "active" : "")
                @(isFilled ? "filled" : "")">
                @(isFilled ? OtpValue[i] : "")
            </div>
        }

    </div>

    <p class="resend-text">
        Resend OTP in
        <span class="timer">00:42</span>
    </p>

    <div class="secure-text">
        ⓘ Your data is 100% secure
    </div>

</div>