@page "/verify-otp"
@layout MainLayout

<div class="ff-otp-shell">

    <button class="ff-otp-back"
            @onclick="GoBack">
        ←
    </button>

    <h1 class="ff-otp-heading">
        Enter OTP
    </h1>

    <p class="ff-otp-description">

        Enter the 6-digit code sent to

        <span class="ff-otp-email">
            john@example.com
        </span>

    </p>

    <div class="ff-otp-code-wrapper"
         @onclick="FocusInput">

        <input @ref="_otpInput"
               class="ff-otp-hidden-input"
               maxlength="6"
               inputmode="numeric"
               value="@OtpValue"
               @oninput="HandleOtpInput" />

        @for (int i = 0; i < 6; i++)
        {
            var isActive = OtpValue.Length == i;
            var isFilled = OtpValue.Length > i;

            <div class="
                 ff-otp-digit-box
                 @(isFilled ? "ff-otp-digit-filled" : "")
                 @(isActive ? "ff-otp-digit-active" : "")">

                @(isFilled ? OtpValue[i] : "")

            </div>
        }

    </div>

    <button class="ff-otp-verify-btn"
            @onclick="Verifyotp">

        Verify

    </button>

    @if (CanResend)
    {
        <p class="ff-otp-resend-section">

            <span class="ff-otp-resend-link"
                  @onclick="ResendOtp">

                Resend OTP

            </span>

        </p>
    }
    else
    {
        <p class="ff-otp-resend-section">

            Resend OTP in

            <span class="ff-otp-countdown">
                @TimeRemaining
            </span>

        </p>
    }

    <div class="ff-otp-security-note">
        ⓘ Your data is 100% secure
    </div>

</div>