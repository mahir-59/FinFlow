@page "/verify-otp"
@layout MainLayout

<div class="auth-container">

    <div class="back-btn">
        <i class="fas fa-arrow-left"></i>
    </div>

    <div class="auth-content">

        <h1>Enter OTP</h1>

        <p class="subtitle">
            Enter the 6-digit code sent to
        </p>

        <p class="email-text">
            yourname@email.com
        </p>

        <div class="otp-container">

            <input maxlength="1" class="otp-box" />
            <input maxlength="1" class="otp-box" />
            <input maxlength="1" class="otp-box" />
            <input maxlength="1" class="otp-box" />
            <input maxlength="1" class="otp-box" />
            <input maxlength="1" class="otp-box" />

        </div>

        <p class="resend-text">
            Resend OTP in
            <span>00:42</span>
        </p>

    </div>

    <div class="secure-card">

        <i class="fas fa-shield-alt"></i>

        <span>Email verification secure</span>

    </div>

    <p class="secure-text">
        Your data is 100% secure
    </p>

</div>
