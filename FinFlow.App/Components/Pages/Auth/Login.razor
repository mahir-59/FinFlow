@page "/login"
@layout MainLayout
@using FinFlow.Modules.Auth.Auth.BL.Interfaces
@inject ILoginViewModel _loginViewModel

<div class="ff-login-shell">

    <div class="ff-login-back-btn" @onclick="GoBack">
        <span>&larr;</span>
    </div>

    <div class="ff-login-content">

        <h1 class="ff-login-title">Welcome back!</h1>

        <p class="ff-login-subtitle">
            Login to continue
        </p>

        <EditForm Model="@LoginRequest" OnValidSubmit="SubmitBtn">
            <DataAnnotationsValidator />

            <div class="ff-login-field">

                <label>Username</label>

                <div class="ff-login-input-wrapper">

                    <InputText
                        @bind-Value="LoginRequest.Username"
                        placeholder="Enter username"
                        class="ff-login-input" />

                </div>

                <ValidationMessage
                    class="ff-login-validation"
                    For="@(() => LoginRequest.Username)" />

            </div>

            <div class="ff-login-field">

                <label>Password</label>

                <div class="ff-login-password-wrapper">

                    <InputText
                        type="@(showPassword ? "text" : "password")"
                        @bind-Value="LoginRequest.Password"
                        placeholder="Enter password"
                        class="ff-login-input" />

                    <button type="button"
                            class="ff-login-eye-btn"
                            @onclick="() => showPassword = !showPassword">

                        <i class="@(showPassword ? "fa-solid fa-eye-slash" : "fa-solid fa-eye")"></i>

                    </button>

                </div>

                <ValidationMessage
                    class="ff-login-validation"
                    For="@(() => LoginRequest.Password)" />

            </div>

            <div class="ff-login-forgot">
                <a href="/forgot-password">Forgot Password?</a>
            </div>

            <button class="ff-login-submit-btn">
                Login
            </button>

        </EditForm>

    </div>

    <div class="ff-login-footer">
        New here?
        <a href="/register">Register now</a>
    </div>

</div>
